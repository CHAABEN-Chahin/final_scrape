# Copy this file to .env and fill your real values.

# Email listener configuration
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password
EMAIL_FOLDER=INBOX

# Groq LLM configuration
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=your_groq_api_key
GROQ_LLM_MODEL=llama-3.3-70b-versatile
GROQ_LLM_SYSTEM_PROMPT=You are an analyst. Produce a concise final answer using both text and image analysis.

# Ollama VLM configuration (no API key required when already authenticated)
OLLAMA_VLM_MODEL=qwen3.5:397b-cloud
OLLAMA_VLM_PROMPT=What is in this image? Be concise.
